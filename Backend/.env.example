# ─── Database ─────────────────────────────────────────────
DB=your_database_name
HOST=localhost
USER=your_db_user
PASSWORD=your_db_password
DB_PORT=3306
dialect=mysql

# ─── Server ───────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ─── Auth (JWT) ───────────────────────────────────────────
# REQUIRED in production. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Token lifetime in seconds (default 86400 = 1 day)
JWT_EXPIRES_IN=86400

# ─── MSG91 OTP (server-side verification) ─────────────────
# REQUIRED. The account auth key used to verify the widget access-token.
MSG91_AUTH_KEY=
MSG91_WIDGET_ID=
# Override only if MSG91 changes their endpoint.
# MSG91_VERIFY_URL=https://control.msg91.com/api/v5/widget/verifyAccessToken

# ─── Mail (SMTP) — only if email features are used ────────
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ─── Observability ────────────────────────────────────────
# Log level: debug|info|warn|error (default info in production)
LOG_LEVEL=info
# If set, /metrics requires ?token=<value> or X-Metrics-Token header.
METRICS_TOKEN=

